<mujoco model="hoppy">

  <compiler meshdir="meshes/" angle="radian" balanceinertia="true"/>

  <option gravity="0 0 -9.81" timestep="0.001"
          integrator="RK4"
          solver="Newton"
          iterations="50"
          tolerance="1e-8"/>

  <default>
    <geom contype="1" conaffinity="1" friction="0.8 0.02 0.001"/>
    <joint damping="0.1"/>
  </default>

  <asset>
    <mesh name="base"  file="base.stl"  scale="0.001 0.001 0.001"/>
    <mesh name="link1" file="link1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link2" file="link2.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link3" file="link3.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link4" file="link4.stl" scale="0.001 0.001 0.001"/>
    <mesh name="foot"  file="foot.stl"  scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.5 0.5 0.5" />
    <light name="ambient" pos="0 0 10" dir="0 0 -1" diffuse="0.5 0.5 0.5" specular="0.0 0.0 0.0" />

    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0.99"
      solref="0.005 1"
      solimp="0.9 0.95 0.001 0.5 2"
      friction="1.0 0.02 0.001"/>

    <body name="base" pos="0 0 1.0">
      <inertial pos="0.025 -2.096e-4 -0.05"
                mass="0.155"
                fullinertia="4.832e-4 4.793e-4 2.892e-4 -7.479e-11 2.634e-8 -2.689e-8"/>
      <geom type="mesh" mesh="base" contype="0" conaffinity="0"/>

      <body name="link1" pos="0 0 0">
        <joint name="gantry_rotation" type="hinge" axis="0 0 1"
               damping="0.1" armature="0.0"/>
        <inertial pos="-1.368e-7 -0.078 0.011"
                  mass="0.155"
                  fullinertia="0.001 0.001 1.691e-4 -4.298e-10 -1.019e-9 -6.170e-6"/>
        <geom type="mesh" mesh="link1"/>

        <body name="link2" pos="0 0 0.19">
          <joint name="gantry_pitch" type="hinge" axis="1 0 0"
                range="-1.5708 1.5708" damping="0.5" armature="0.0"/>

          <inertial pos="0.026 -0.202 2.010e-4"
                    mass="0.831"
                    fullinertia="0.046 0.001 0.047 0.003 2.421e-6 -4.776e-5"/>
          <geom type="mesh" mesh="link2"/>

          <body name="counterweight" pos="-0.005 0.270 0">
            <geom type="sphere" size="0.05" mass="1.65"
              contype="0" conaffinity="0"/>
          </body>

          <body name="link3" pos="0.058 -0.576 0">
            <joint name="hip" type="hinge" axis="0 1 0"
                   range="-1.5708 1.5708"
                   damping="0.1788"
                   armature="0.005058"/>
            <inertial pos="0.0145 0.0315 -0.005"
                     mass="0.512"
                     fullinertia="0.001 0.001 0.001 -3.387e-4 -9.783e-6 -6.901e-6"/>
            <geom type="mesh" mesh="link3" pos="0.0475 0.0215 0"/>

            <body name="link4" pos="0.096 0.0215 0"
                  quat="0.7071 0 -0.7071 0">

              <joint name="knee" type="hinge" axis="0 1 0"
                     range="0 3.1416"
                     damping="0.2048"
                     armature="0.005806"
                     stiffness="1.1"
                     springref="0"/>
              <inertial pos="-0.002 -0.025 -0.008"
                        mass="0.092"
                        fullinertia="2.305e-4 1.871e-4 6.687e-5 1.703e-6 1.882e-6 -1.875e-5"/>
              <geom type="mesh" mesh="link4"/>

              <geom name="foot_rubber" type="mesh" mesh="foot"
                    pos="0.052 0 -0.150"
                    contype="1" conaffinity="1"
                    friction="2.0 0.02 0.001"
                    solref="0.005 1"
                    solimp="0.99 0.999 0.001"/>

              <site name="foot_site" pos="0.052 0 -0.150" size="0.005"/>

              <body name="foot_sensor_body" pos="0.052 -0.0125 -0.1455">
                <joint name="foot_spring" type="slide" axis="0 0 -1"
                       range="-0.02 0.0"
                       stiffness="2"
                       damping="0.2"
                       springref="0.0"/>
                <inertial pos="0 0 0"
                          mass="0.005"
                          diaginertia="1e-6 1e-6 1e-6"/>
                <geom name="foot_sensor_cylinder" type="cylinder"
                      size="0.002 0.020"
                      pos="0 0 0"
                      contype="1" conaffinity="1"
                      solref="0.005 1"
                      solimp="0.99 0.999 0.001"
                      friction="1.0 0.02 0.001"/>
              </body>

            </body>
          </body>
        </body>
      </body>
    </body>

  </worldbody>

  <actuator>
    <motor name="hip_motor"  joint="hip"  gear="1"
           ctrlrange="-3.728 3.728" ctrllimited="true"/>
    <motor name="knee_motor" joint="knee" gear="1"
           ctrlrange="-3.728 3.728" ctrllimited="true"/>
  </actuator>

  <sensor>
    <jointpos name="gantry_pitch_pos" joint="gantry_pitch"/>
    <jointpos name="gantry_rot_pos"   joint="gantry_rotation"/>
    <jointpos name="hip_pos"          joint="hip"/>
    <jointpos name="knee_pos"         joint="knee"/>

    <jointvel name="gantry_pitch_vel" joint="gantry_pitch"/>
    <jointvel name="gantry_rot_vel"   joint="gantry_rotation"/>
    <jointvel name="hip_vel"          joint="hip"/>
    <jointvel name="knee_vel"         joint="knee"/>

    <actuatorfrc name="hip_torque"  actuator="hip_motor"/>
    <actuatorfrc name="knee_torque" actuator="knee_motor"/>

    <jointpos name="foot_compression" joint="foot_spring"/>
    <jointvel name="foot_spring_vel"  joint="foot_spring"/>

  </sensor>

</mujoco>